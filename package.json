{
  "name": "intrigue",
  "productName": "Intrigue",
  "version": "1.4.0",
  "private": true,
  "description": "Organize literature into ideas, fast.",
  "author": "Shengchen Zhang <shengchenzhang1207@gmail.com> [https://shengchen.design/]",
  "scripts": {
    "serve": "electron-vite dev",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint . --ext .js,.vue",
    "electron:build": "electron-vite build && electron-builder",
    "electron:serve": "electron-vite dev",
    "postinstall": "node ./node_modules/electron/install.js && electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps"
  },
  "main": "./out/main/background.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.31.0",
    "@syncedstore/core": "^0.4.1",
    "@tiptap/extension-highlight": "^2.0.0-beta.35",
    "@tiptap/extension-link": "^2.0.0-beta.41",
    "@tiptap/extension-strike": "^2.1.16",
    "@tiptap/extension-underline": "^2.1.16",
    "@tiptap/starter-kit": "^2.0.0-beta.185",
    "@tiptap/vue-3": "^2.0.0-beta.91",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vue-flow/node-resizer": "^1.5.1",
    "@vue-flow/node-toolbar": "^1.1.1",
    "@xstate/vue": "^2.0.0",
    "axios": "^1.1.2",
    "citation-js": "^0.6.2",
    "copy-to-clipboard-ultralight": "^1.0.15",
    "core-js": "^3.23.1",
    "electron-is": "^3.0.0",
    "electron-log": "^4.4.8",
    "identifiers-doi": "^0.2.1",
    "is-electron": "^2.2.1",
    "linkifyjs": "^4.0.2",
    "nanoid": "^4.0.0",
    "random-fruits-name": "^1.9.5",
    "tinykeys": "^1.4.0",
    "vue": "^3.2.37",
    "vue-boring-avatars": "^1.1.0",
    "xstate": "^4.32.1",
    "y-indexeddb": "^9.0.8",
    "y-webrtc": "^10.2.3",
    "yaml": "^2.1.1",
    "yjs": "^13.5.39"
  },
  "devDependencies": {
    "@babel/core": "^7.18.5",
    "@babel/eslint-parser": "^7.18.2",
    "@electron/notarize": "^3.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-airbnb": "^6.0.0",
    "electron": "^41.9.0",
    "electron-builder": "^26.15.3",
    "electron-devtools-installer": "^3.2.0",
    "electron-vite": "^5.0.0",
    "eslint": "^8.18.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-vue": "^9.1.1",
    "eslint-plugin-vuejs-accessibility": "^1.2.0",
    "sass": "^1.52.3",
    "vite": "^7.3.6"
  },
  "build": {
    "productName": "Intrigue",
    "appId": "design.shengchen.intrigue",
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "afterSign": "build/notarize.cjs",
    "mac": {
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist"
    },
    "fileAssociations": [
      {
        "ext": "intrigue",
        "name": "Intrigue Literature Map",
        "description": "Intrigue literature map file.",
        "role": "Editor",
        "icon": "document.icns"
      }
    ]
  }
}
